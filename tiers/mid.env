# Vision Labs — MID tier preset
#
# Target: single NVIDIA GPU with 8-12 GB VRAM (RTX 3060, 4060, 4070).
# This is the project's default and recommended config for typical home setups
# (1-3 cameras + responsive AI chat assistant).
#
# You get everything in 'small' plus:
#   - Qwen 3 7B chat assistant (~5 GB VRAM, fast on 8 GB+)
#   - Optional vision LLM (uncomment VISION_MODEL line below to enable;
#     needs another ~5 GB VRAM, only fits if you have 12 GB)
#   - 's' (small) YOLO models — same as full tier, ~15-20% better accuracy
#     than nano variants
#
# How to apply:
#   cat tiers/mid.env >> .env
#   docker compose up -d

DETECTOR_GPU=0
CHAT_GPU=0

POSE_MODEL=/models/yolov8s-pose.pt
VEHICLE_MODEL=/models/yolov8s.pt

CHAT_MODEL=qwen3:7b

# Vision LLM disabled by default on mid tier (would need ~10-11 GB combined
# with chat). Uncomment if you have a 12 GB card and want image analysis.
# VISION_MODEL=minicpm-v
VISION_MODEL=

TARGET_FPS=10
