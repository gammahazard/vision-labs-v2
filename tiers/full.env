# Vision Labs — FULL tier preset
#
# Target: single 16+ GB GPU OR dual-GPU workstation.
# Everything enabled: 14B chat, vision LLM, 's' detector models.
#
# On a SINGLE 16+ GB GPU: leave CHAT_GPU=0 (everything on one card).
# On DUAL-GPU systems: change CHAT_GPU=1 below to put ollama on the second
#   card and keep ~9 GB free for many cameras' detectors on GPU 0.
#
# How to apply:
#   cat tiers/full.env >> .env
#   docker compose up -d

DETECTOR_GPU=0
# Single-GPU default. Change to 1 if you have a dedicated second card for the LLM.
CHAT_GPU=0

POSE_MODEL=/models/yolov8s-pose.pt
VEHICLE_MODEL=/models/yolov8s.pt

CHAT_MODEL=qwen3:14b
VISION_MODEL=minicpm-v

TARGET_FPS=15
