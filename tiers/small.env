# Vision Labs — SMALL tier preset
#
# Target: single NVIDIA GPU with 6 GB VRAM (GTX 1660 Ti, RTX 3050, RTX 2060).
# Trade-off: AI chat assistant is OFF (saves ~5-9 GB VRAM). You still get:
#   - Person, vehicle, and face detection on every frame
#   - DVR recording, event timeline, Telegram notifications
#   - Zones, scheduling, retention prune
# What's missing vs mid/full:
#   - AI Chat tab (Qwen LLM) — disabled
#   - Vision LLM image analysis — disabled
#
# How to apply:
#   cat tiers/small.env >> .env
#   docker compose up -d
#
# To switch tiers later: remove these lines from .env and append a different
# tier file (or just edit the values in place).

DETECTOR_GPU=0
CHAT_GPU=0

# Nano YOLO models — ~3-5× faster than the 's' variants at ~85-90% of the
# accuracy. The trade-off is worth it on 6 GB cards.
POSE_MODEL=/models/yolov8n-pose.pt
VEHICLE_MODEL=/models/yolov8n.pt

# Empty = AI chat fully disabled (dashboard hides the tab, warmup poller skips)
CHAT_MODEL=
VISION_MODEL=

# Lower frame rate to stay within the GPU's inference budget
TARGET_FPS=5
