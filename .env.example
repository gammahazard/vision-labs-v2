# NOTE — cameras are added via the dashboard wizard (Cameras tab or first-run
# setup), NOT via this file. Each camera's RTSP credentials, detection flags,
# and slot id live in the Redis `cameras:registry` hash. The legacy
# CAMERA_IP / CAMERA_USER / CAMERA_PASSWORD / RTSP_MAIN / RTSP_SUB env vars
# from older single-camera deployments are no longer required and have been
# removed from this template. A first-time install will work with a blank
# camera setup and prompt you for your first camera in the wizard.

# Telegram Bot — the setup wizard offers to connect this for you, including
# automatic chat-ID discovery (you just message your bot once). If you'd
# rather configure manually: get a bot token from @BotFather and find your
# chat ID via @userinfobot, then set both here and restart the dashboard.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to send bot commands. Leave
# empty to seed from TELEGRAM_CHAT_ID. The dashboard's first telegram
# message stamps the user in the access log; you can add more via the
# Telegram tab.
TELEGRAM_ALLOWED_USERS=

# OpenWeatherMap (optional — conditions panel)
# Sign up free at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Camera location — used for sunrise/sunset calculations (astral) AND for
# AI date queries ("today" / "yesterday"). LOCATION_TIMEZONE is validated at
# startup by contracts/tz.py — invalid IANA names will refuse to boot the
# affected service (intentional: silent fallback caused day-boundary bugs).
# Common values: America/Toronto, America/New_York, America/Los_Angeles,
# Europe/London, Europe/Berlin, Asia/Tokyo, Australia/Sydney, UTC.
# Full list: `python3 -c "from zoneinfo import available_timezones; print('\n'.join(sorted(available_timezones())))"`
LOCATION_NAME=Toronto
LOCATION_REGION=Ontario
LOCATION_TIMEZONE=America/Toronto
LOCATION_LAT=43.6532
LOCATION_LON=-79.3832

# QNAP NAS (CIFS/SMB volumes). Set QNAP_ENABLED=false to run without NAS.
# When true, also use: docker compose --profile nas up
QNAP_ENABLED=false
QNAP_IP=192.168.1.250
QNAP_USER=visionlabs
# Leave blank so an unconfigured NAS mount fails loudly rather than trying a
# guessable default. Set a real value only when QNAP_ENABLED=true.
QNAP_PASSWORD=

# Local snapshot/event retention in days (used when QNAP is off).
# 0 = never prune, default = 4. The dashboard runs a daily cleanup task.
SNAPSHOT_RETENTION_DAYS=4

# Video clip retention (separate, shorter — clips are bigger than snapshots).
# Used for AI-generated clips and Telegram /clip command outputs in
# /data/snapshots/clips/. Default = 3 days.
CLIP_RETENTION_DAYS=3


# ──────────────────────────────────────────────────────────────────────────
# Hardware tier — model + GPU configuration
# ──────────────────────────────────────────────────────────────────────────
# Defaults below assume a single NVIDIA GPU with 8-12 GB VRAM (e.g. RTX 3060,
# 4060). That's the typical "1-3 cameras + light AI chat" home setup.
#
# Pre-built tier presets live in tiers/{small,mid,full}.env — copy the one
# that matches your hardware into your .env, or set values individually.
# The first-run setup wizard (Phase D) will write these for you automatically.

# Which GPU runs detection? (pose, vehicle, face)
# Index matches `nvidia-smi -L` output. Default 0 = first/only GPU.
DETECTOR_GPU=0

# Which GPU runs the chat LLM? (ollama: Qwen 3 + MiniCPM-V)
# Default 0 = same card as detectors (single-GPU mode).
# Set to 1 if you have a second GPU and want to dedicate it to the LLM.
CHAT_GPU=0

# YOLO models — '.n' (nano) variants for small tier, '.s' for mid/full.
# Files live in the yolo-models Docker volume, auto-downloaded by ultralytics
# the first time the path is referenced.
POSE_MODEL=/models/yolov8s-pose.pt
VEHICLE_MODEL=/models/yolov8s.pt

# Chat LLM model name (must exist on the Ollama server, auto-pulled on first
# request). Set to empty string ("") to disable AI chat entirely — the chat
# tab will show "disabled on this hardware tier" and the warmup poller skips.
# Saves ~5-9 GB of VRAM when disabled.
#
# Sized options (rough VRAM footprint when loaded — ollama unloads after
# 5 min idle, so this is "while in use", not "always"):
#   qwen3:14b     ~9 GB   — full reasoning + tool calling, recommended on 12+ GB cards
#   qwen3:7b      ~5 GB   — good middle ground for 8-12 GB cards
#   qwen3:3b      ~2 GB   — light chat on 6-8 GB cards
#   qwen3:1.7b    ~1.5 GB — tiny, works on 4-6 GB cards (less smart, but functional)
#   llama3.2:3b   ~2 GB   — alternative to qwen3:3b
#   phi3:mini     ~2 GB   — Microsoft's tiny model; fast on weak GPUs
#   ""            0       — AI chat fully disabled
#
# All `qwen3:*` and `llama3.2:*` support the 19 tool functions the assistant
# uses. `phi3:mini` doesn't support tool calling — it can chat but not query
# events/snap photos/etc., so most tool-using features become unavailable.
CHAT_MODEL=qwen3:14b

# Vision LLM for image analysis (Vision tab). Set to empty string to disable.
# minicpm-v is ~5 GB VRAM.
VISION_MODEL=minicpm-v

# End-to-end frame rate (camera-ingester → detectors → dashboard).
# Lower this on slower GPUs / when running many cameras.
# Small tier: 5, mid: 10, full: 15.
TARGET_FPS=10

# ──────────────────────────────────────────────────────────────────────────
# Detector / tracker tuning — all optional, defaults preserve historic
# behavior. Promoted to env vars so you can change any of these without
# rebuilding the image (just `docker compose up -d <service>`).
# ──────────────────────────────────────────────────────────────────────────

# tracker.py
# MAX_EVENT_STREAM_LEN=5000          # cap on events:{cam} stream length
# VEHICLE_RATE_LIMIT_SEC=3           # min seconds between vehicle events
# VEHICLE_LOST_TIMEOUT=10.0          # secs before dropping a tracked vehicle
# VEHICLE_IOU_THRESHOLD=0.2          # parked-car IoU (lower than person)
# CONFIG_RELOAD_INTERVAL=10          # re-read config every N detections
# ACTION_DEBOUNCE_FRAMES=10          # frames a new action must be stable for
# ACTION_STICKY_MULTIPLIER=2         # once set, require N×multiplier to change
# MIN_BBOX_AREA=3072                 # skip detections smaller than this (px²)
# IDENTITY_GRACE_SECONDS=4.0         # when suppress_known on, wait this long
                                     # for face recognition to identify them

# pose-detector + vehicle-detector
# MAX_DETECTION_STREAM_LEN=1000      # cap detections:{type}:{cam} stream length

# face_db (already env-overridable, listed for completeness)
# MAX_UNKNOWN_FACES=100              # cap on unknown_faces gallery
# UNKNOWN_DEDUP_THRESHOLD=0.6        # cosine sim threshold for unknown dedup
# CACHE_REFRESH_INTERVAL=30          # how often each face-recognizer reloads
                                     # its in-memory cache from the shared DB

# ---------------------------------------------------------------------------
# Redis AUTH (optional but recommended)
# ---------------------------------------------------------------------------
# Set a strong password to require AUTH on all Redis connections.
# Empty (default) = no auth (any process on the host can read face embeddings,
# RTSP credentials, and event history via redis-cli — fine for an air-gapped
# dev box, not for any kind of shared/exposed environment).
#
# To enable: set a 32+ char random value, then `docker compose restart`.
#   REDIS_PASSWORD=$(openssl rand -hex 32)
#
# All Python clients honor this via contracts/redis_client.py automatically.
# REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Grafana admin password
# ---------------------------------------------------------------------------
# Auto-generated by scripts/install-linux.sh. NEVER commit a real value —
# this repo is public, so a hardcoded password = world-readable Grafana admin.
# The embedded dashboard panels use anonymous Viewer, so leaving this unset
# in dev only affects the admin/edit login (Grafana falls back to its own
# default). Set a strong value for any LAN-reachable deployment.
# GRAFANA_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# /metrics bearer token
# ---------------------------------------------------------------------------
# Auto-generated by scripts/install-linux.sh into BOTH this var and the
# gitignored services/prometheus/metrics_token file Prometheus reads. The
# dashboard's /metrics (on LAN-reachable :8080) requires this bearer token.
# Unset = /metrics served open with a logged warning. Never commit a value.
# METRICS_TOKEN=

# ---------------------------------------------------------------------------
# Cookie hardening (only set when the dashboard is behind a TLS terminator)
# ---------------------------------------------------------------------------
# When true, the session cookie is set with `secure=True` so browsers refuse
# to send it over plain HTTP. DO NOT enable this without an actual TLS proxy
# (Tailscale Serve, Cloudflare Tunnel, nginx) — your phone won't be able to
# log in over http://192.168.x.y:8080 once this is on.
# DASHBOARD_BEHIND_TLS=false

# ---------------------------------------------------------------------------
# Vehicle attributes pipeline (Phase 1 → 3, added 2026-05-22)
# ---------------------------------------------------------------------------
# Per-camera vehicle-attributes service captures HD crops on `vehicle_sample`
# events from the tracker, then optionally runs a ConvNeXt-Tiny multi-head
# classifier at vehicle_gone-flush time to fill color / body / make / model.
#
# Tracker-side knobs (these gate sample emission upstream):
#   EMIT_VEHICLE_SAMPLES=0/1           Set =1 to fire vehicle_sample events.
#                                       Default 0 — no samples flow into
#                                       vehicle-attributes. Set =1 to enable.
#   SAMPLE_INTERVAL_FRAMES=3           After the eager window, emit one sample
#                                       every N matched updates per track.
#   EAGER_SAMPLE_FRAMES=8              First N matched updates of a track emit
#                                       a sample every frame — fills the
#                                       reservoir for short drive-bys.
#   MIN_SAMPLE_BBOX_AREA_SUB_PX=1500   Skip sample emission below this bbox
#                                       area in sub-stream pixels. Drops noise.
#
# vehicle-attributes-side knobs (consumption + crop quality):
#   MAX_BUFFER_CROPS=8                 Reservoir size per track.
#   MIN_CROP_AREA_HD_PX=2500           Skip crops below 50×50 in HD coords.
#   CROP_PADDING_PCT=0.35              Pad bbox by 35% before crop.
#   JPEG_QUALITY=85
#   HD_FRAME_WIDTH=2304
#   HD_FRAME_HEIGHT=1296
#
# Classifier (Phase 3 — disabled by default until trained weights exist
# in the HF Hub repo):
#   ENABLE_CLASSIFIER=0/1              =1 turns on the ConvNeXt-Tiny pipeline.
#                                       Requires the weights repo below to
#                                       actually contain a checkpoint.
#   VEHICLE_ATTR_HF_REPO=mangolover/vision-labs-vehicle-attributes
#   VEHICLE_ATTR_MODEL=convnext_tiny_v0
#   COLOR_CONF_THRESHOLD=0.45
#   BODY_CONF_THRESHOLD=0.50
#   MAKE_CONF_THRESHOLD=0.65
#   MODEL_CONF_THRESHOLD=0.55
