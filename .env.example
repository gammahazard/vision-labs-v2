# Reolink Camera
CAMERA_IP=192.168.1.x
CAMERA_USER=admin
CAMERA_PASSWORD=changeme
RTSP_MAIN=rtsp://admin:${CAMERA_PASSWORD}@${CAMERA_IP}:554/h264Preview_01_main
RTSP_SUB=rtsp://admin:${CAMERA_PASSWORD}@${CAMERA_IP}:554/h264Preview_01_sub

# Telegram Bot — get token from @BotFather, find your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to send bot commands
TELEGRAM_ALLOWED_USERS=

# OpenWeatherMap (optional — conditions panel)
# Sign up free at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Camera location — used for sunrise/sunset calculations (astral)
LOCATION_NAME=Toronto
LOCATION_REGION=Ontario
LOCATION_TIMEZONE=America/Toronto
LOCATION_LAT=43.6532
LOCATION_LON=-79.3832

# QNAP NAS (CIFS/SMB volumes). Set QNAP_ENABLED=false to run without NAS.
# When true, also use: docker compose --profile nas up
QNAP_ENABLED=false
QNAP_IP=192.168.1.250
QNAP_USER=visionlabs
QNAP_PASSWORD=changeme

# Local snapshot/event retention in days (used when QNAP is off).
# 0 = never prune, default = 4. The dashboard runs a daily cleanup task.
SNAPSHOT_RETENTION_DAYS=4

# ──────────────────────────────────────────────────────────────────────────
# Detector / tracker tuning — all optional, defaults preserve historic
# behavior. Promoted to env vars so you can change any of these without
# rebuilding the image (just `docker compose up -d <service>`).
# ──────────────────────────────────────────────────────────────────────────

# tracker.py
# MAX_EVENT_STREAM_LEN=5000          # cap on events:{cam} stream length
# VEHICLE_RATE_LIMIT_SEC=3           # min seconds between vehicle events
# VEHICLE_LOST_TIMEOUT=10.0          # secs before dropping a tracked vehicle
# VEHICLE_IOU_THRESHOLD=0.2          # parked-car IoU (lower than person)
# CONFIG_RELOAD_INTERVAL=10          # re-read config every N detections
# ACTION_DEBOUNCE_FRAMES=10          # frames a new action must be stable for
# ACTION_STICKY_MULTIPLIER=2         # once set, require N×multiplier to change
# MIN_BBOX_AREA=3072                 # skip detections smaller than this (px²)
# IDENTITY_GRACE_SECONDS=4.0         # when suppress_known on, wait this long
                                     # for face recognition to identify them

# pose-detector + vehicle-detector
# MAX_DETECTION_STREAM_LEN=1000      # cap detections:{type}:{cam} stream length

# face_db (already env-overridable, listed for completeness)
# MAX_UNKNOWN_FACES=100              # cap on unknown_faces gallery
# UNKNOWN_DEDUP_THRESHOLD=0.6        # cosine sim threshold for unknown dedup
# CACHE_REFRESH_INTERVAL=30          # how often each face-recognizer reloads
                                     # its in-memory cache from the shared DB
